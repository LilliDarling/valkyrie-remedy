{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "valkyrie-remedy",
  "main": "./dist/_worker.js/index.js",
  "compatibility_date": "2026-04-28",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  }
}
