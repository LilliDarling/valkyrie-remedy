---
import Nav from "../components/Nav.astro";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  bodyClass?: string;
  ogImage?: string;
  ogType?: "website" | "article" | "profile";
  noindex?: boolean;
}

const {
  title,
  description = "Code reviews, rebuilds, and security audits for founders and creators who shipped a site with AI and now need it made real.",
  bodyClass = "",
  ogImage = "/Valkyrie.png",
  ogType = "website",
  noindex = false,
} = Astro.props;

const fullTitle =
  title === "Valkyrie Remedy" ? title : `${title} — Valkyrie Remedy`;

const siteOrigin = Astro.site
  ? new URL(Astro.site).origin
  : "https://valkyrieremedy.com";
const canonical = new URL(Astro.url.pathname, siteOrigin).href;
const absoluteOgImage = ogImage
  ? new URL(ogImage, siteOrigin).href
  : undefined;

// JSON-LD structured data identifying the practice. Helps search engines
// understand who this is and surfaces rich-result eligibility.
const orgLd: Record<string, unknown> = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  name: "Valkyrie Remedy",
  url: siteOrigin,
  email: "hello@valkyrieremedy.com",
  description,
  priceRange: "$$",
  serviceType: [
    "Code review",
    "Security audit",
    "Web rebuild",
    "Software architecture consulting",
  ],
  areaServed: "Worldwide",
  sameAs: [],
};
if (absoluteOgImage) orgLd.image = absoluteOgImage;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="color-scheme" content="dark" />
    <meta name="theme-color" content="#060606" />
    <meta name="description" content={description} />
    <meta name="author" content="Valkyrie Remedy" />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/png" href="/Valkyrie.png" sizes="500x500" />
    <link rel="apple-touch-icon" href="/Valkyrie.png" />
    <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Valkyrie Remedy" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    {
      absoluteOgImage && (
        <>
          <meta property="og:image" content={absoluteOgImage} />
          <meta property="og:image:width" content="500" />
          <meta property="og:image:height" content="500" />
          <meta property="og:image:alt" content="Valkyrie Remedy" />
        </>
      )
    }

    <!-- Twitter / X -->
    <meta
      name="twitter:card"
      content={absoluteOgImage ? "summary" : "summary"}
    />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    {absoluteOgImage && <meta name="twitter:image" content={absoluteOgImage} />}

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,500;0,8..60,600;1,8..60,400;1,8..60,500&family=JetBrains+Mono:wght@400;500&display=swap"
    />

    <title>{fullTitle}</title>

    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(orgLd)}
    />
    {/* Per-page structured data extension via slot */}
    <slot name="structured-data" />

    <script is:inline>
      // Mark JS available before paint so the reveal CSS can engage.
      document.documentElement.classList.add("vr-js");
    </script>
  </head>
  <body class={bodyClass}>
    <a href="#main" class="skip">Skip to content</a>
    <Nav />
    <main id="main">
      <slot />
    </main>
    <footer class="vr-footer">
      <div class="vr-shell vr-footer__row">
        <span class="vr-footer__mark">— Valkyrie Remedy</span>
        <span>© {new Date().getFullYear()} · Independent practice</span>
        <span class="vr-footer__links">
          <a href="/privacy">Privacy</a>
          <span aria-hidden="true">·</span>
          <a href="/terms">Terms</a>
          <span aria-hidden="true">·</span>
          <a href="mailto:hello@valkyrieremedy.com">hello@valkyrieremedy.com</a>
        </span>
      </div>
    </footer>

    <script>
      import Lenis from "lenis";

      const reducedMotion = window.matchMedia(
        "(prefers-reduced-motion: reduce)"
      ).matches;

      // ---------- Smooth scroll (Lenis) ----------
      if (!reducedMotion) {
        const lenis = new Lenis({
          lerp: 0.08,
          smoothWheel: true,
          wheelMultiplier: 0.9,
          touchMultiplier: 1.5,
          syncTouch: true,
        });

        const raf = (time: number) => {
          lenis.raf(time);
          requestAnimationFrame(raf);
        };
        requestAnimationFrame(raf);

        // Anchor links: hand off to Lenis so they animate the same way.
        document.addEventListener("click", (e) => {
          const target = e.target as HTMLElement | null;
          const link = target?.closest<HTMLAnchorElement>('a[href^="#"]');
          if (!link) return;
          const id = link.getAttribute("href");
          if (!id || id === "#") return;
          const el = document.querySelector(id);
          if (!el) return;
          e.preventDefault();
          lenis.scrollTo(el as HTMLElement, { offset: 0 });
        });
      }

      // ---------- Cursor light ----------
      const supportsHover = window.matchMedia("(hover: hover)").matches;

      if (supportsHover && !reducedMotion) {
        const root = document.documentElement;
        let pending = false;
        let nx = 0.5;
        let ny = 0.5;
        let active = false;

        const flush = () => {
          pending = false;
          root.style.setProperty(
            "--vr-cursor-x",
            (nx * 100).toFixed(1) + "%"
          );
          root.style.setProperty(
            "--vr-cursor-y",
            (ny * 100).toFixed(1) + "%"
          );
          if (!active) {
            active = true;
            root.style.setProperty("--vr-cursor-strength", "1");
          }
        };

        document.addEventListener("mousemove", (e) => {
          nx = e.clientX / window.innerWidth;
          ny = e.clientY / window.innerHeight;
          if (!pending) {
            pending = true;
            requestAnimationFrame(flush);
          }
        });

        document.addEventListener("mouseleave", () => {
          active = false;
          root.style.setProperty("--vr-cursor-strength", "0");
        });
      }

      // ---------- Reveals ----------
      const reveals = document.querySelectorAll<HTMLElement>("[data-reveal]");

      if (reveals.length) {
        // Above the fold: paint immediately.
        reveals.forEach((el) => {
          const r = el.getBoundingClientRect();
          if (r.top < window.innerHeight && r.bottom > 0) {
            el.classList.add("is-in");
          }
        });

        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add("is-in");
                io.unobserve(e.target);
              }
            });
          },
          { threshold: 0.1, rootMargin: "0px 0px -80px 0px" }
        );

        reveals.forEach((el) => {
          if (!el.classList.contains("is-in")) io.observe(el);
        });

        // Safety net for anything that should be on screen but missed the observer.
        window.setTimeout(() => {
          document
            .querySelectorAll<HTMLElement>("[data-reveal]:not(.is-in)")
            .forEach((el) => {
              const r = el.getBoundingClientRect();
              if (r.top < window.innerHeight + 200) el.classList.add("is-in");
            });
        }, 1200);
      }
    </script>

    <style>
      .skip {
        position: absolute;
        top: -40px;
        left: 1rem;
        padding: 0.5rem 1rem;
        background: var(--vr-gold);
        color: var(--vr-ink);
        font-family: var(--vr-mono);
        font-size: 0.8rem;
        z-index: 200;
        transition: top 180ms var(--vr-ease);
      }
      .skip:focus { top: 0.5rem; }

      .vr-footer {
        margin-top: clamp(5rem, 10vw, 8rem);
        padding: 3rem 0 2rem;
        border-top: 1px solid var(--vr-rule);
        font-family: var(--vr-mono);
        font-size: var(--vr-step--1);
        color: var(--vr-bone-faint);
        text-transform: uppercase;
        letter-spacing: 0.06em;
      }
      .vr-footer__row {
        display: flex;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 1rem;
      }
      .vr-footer__mark {
        font-family: var(--vr-serif);
        font-style: italic;
        text-transform: none;
        letter-spacing: 0;
        color: var(--vr-bone-dim);
      }
      .vr-footer__links {
        display: inline-flex;
        gap: 0.6rem;
        align-items: baseline;
      }
      .vr-footer__links a {
        color: var(--vr-bone-faint);
        transition: color 220ms var(--vr-ease);
      }
      .vr-footer__links a:hover {
        color: var(--vr-bone);
      }
    </style>
  </body>
</html>
