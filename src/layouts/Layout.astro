---
import Nav from "../components/Nav.astro";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Code reviews, rebuilds, and security audits for founders and creators who shipped a site with AI and now need it made real.",
} = Astro.props;

const fullTitle =
  title === "Valkyrie Remedy" ? title : `${title} — Valkyrie Remedy`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="color-scheme" content="dark" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#060606" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=JetBrains+Mono:wght@400;500&display=swap"
    />

    <title>{fullTitle}</title>

    <script is:inline>
      // Mark JS available before paint so the reveal CSS can engage.
      document.documentElement.classList.add("vr-js");
    </script>
  </head>
  <body>
    <a href="#main" class="skip">Skip to content</a>
    <Nav />
    <main id="main">
      <slot />
    </main>
    <footer class="vr-footer">
      <div class="vr-shell vr-footer__row">
        <span class="vr-footer__mark">— Valkyrie Remedy</span>
        <span>© {new Date().getFullYear()} · Solo practice</span>
        <span>hello@valkyrieremedy.co</span>
      </div>
    </footer>

    <script>
      // ---------- Cursor light ----------
      const supportsHover = window.matchMedia("(hover: hover)").matches;
      const reducedMotion = window.matchMedia(
        "(prefers-reduced-motion: reduce)"
      ).matches;

      if (supportsHover && !reducedMotion) {
        const root = document.documentElement;
        let pending = false;
        let nx = 0.5;
        let ny = 0.5;
        let active = false;

        const flush = () => {
          pending = false;
          root.style.setProperty(
            "--vr-cursor-x",
            (nx * 100).toFixed(1) + "%"
          );
          root.style.setProperty(
            "--vr-cursor-y",
            (ny * 100).toFixed(1) + "%"
          );
          if (!active) {
            active = true;
            root.style.setProperty("--vr-cursor-strength", "1");
          }
        };

        document.addEventListener("mousemove", (e) => {
          nx = e.clientX / window.innerWidth;
          ny = e.clientY / window.innerHeight;
          if (!pending) {
            pending = true;
            requestAnimationFrame(flush);
          }
        });

        document.addEventListener("mouseleave", () => {
          active = false;
          root.style.setProperty("--vr-cursor-strength", "0");
        });
      }

      // ---------- Reveals ----------
      const reveals = document.querySelectorAll<HTMLElement>("[data-reveal]");

      if (reveals.length) {
        // Above the fold: paint immediately.
        reveals.forEach((el) => {
          const r = el.getBoundingClientRect();
          if (r.top < window.innerHeight && r.bottom > 0) {
            el.classList.add("is-in");
          }
        });

        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add("is-in");
                io.unobserve(e.target);
              }
            });
          },
          { threshold: 0.1, rootMargin: "0px 0px -80px 0px" }
        );

        reveals.forEach((el) => {
          if (!el.classList.contains("is-in")) io.observe(el);
        });

        // Safety net for anything that should be on screen but missed the observer.
        window.setTimeout(() => {
          document
            .querySelectorAll<HTMLElement>("[data-reveal]:not(.is-in)")
            .forEach((el) => {
              const r = el.getBoundingClientRect();
              if (r.top < window.innerHeight + 200) el.classList.add("is-in");
            });
        }, 1200);
      }
    </script>

    <style>
      .skip {
        position: absolute;
        top: -40px;
        left: 1rem;
        padding: 0.5rem 1rem;
        background: var(--vr-gold);
        color: var(--vr-ink);
        font-family: var(--vr-mono);
        font-size: 0.8rem;
        z-index: 200;
        transition: top 180ms var(--vr-ease);
      }
      .skip:focus { top: 0.5rem; }

      .vr-footer {
        margin-top: clamp(5rem, 10vw, 8rem);
        padding: 3rem 0 2rem;
        border-top: 1px solid var(--vr-rule);
        font-family: var(--vr-mono);
        font-size: var(--vr-step--1);
        color: var(--vr-bone-faint);
        text-transform: uppercase;
        letter-spacing: 0.06em;
      }
      .vr-footer__row {
        display: flex;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 1rem;
      }
      .vr-footer__mark {
        font-family: var(--vr-serif);
        font-style: italic;
        text-transform: none;
        letter-spacing: 0;
        color: var(--vr-bone-dim);
      }
    </style>
  </body>
</html>
