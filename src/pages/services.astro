---
import Layout from "../layouts/Layout.astro";
import FinalCta from "../components/FinalCta.astro";

type Service = {
  id: string;
  num: string;
  title: string;
  short: string;
  eyebrow: string;
  lede: string;
  spec: {
    duration: string;
    format: string;
    deliverable: string;
    scope: string;
    from: string;
  };
  checksTitle: string;
  checks: { k: string; v: string }[];
  protocol: { num: string; title: string; body: string }[];
  fit: string;
  alt?: boolean;
};

const services: Service[] = [
  {
    id: "code-review",
    num: "01",
    title: "Code review",
    short: "Review",
    eyebrow: "— 01 ⁄ Review",
    lede: "A close read of what you've built — what holds, what strains, what won't survive a real user. Written, traceable, and triaged.",
    spec: {
      duration: "3–5 days",
      format: "Written report + walkthrough",
      deliverable: "PDF report + repo annotations",
      scope: "1 codebase, 1 repo",
      from: "By project",
    },
    checksTitle: "What gets read.",
    checks: [
      { k: "Architecture", v: "Folder shape, module seams, render strategy." },
      { k: "Data flow", v: "State, fetching, caching. Where the lies live." },
      { k: "Performance", v: "LCP, TTI, layout shift, payload weight." },
      { k: "Accessibility", v: "WCAG AA pass — keyboard, contrast, semantics." },
      { k: "SEO surface", v: "Meta, sitemap, structured data, indexability." },
      { k: "Code health", v: "Dead paths, duplication, hidden coupling." },
    ],
    protocol: [
      {
        num: "i.",
        title: "Kickoff",
        body: "Repo access, deployed URL, the story of how it got here. I read everything before I write a word.",
      },
      {
        num: "ii.",
        title: "Read",
        body: "Static analysis, runtime traces, manual trace of three real user paths. Quiet hours, no Slack.",
      },
      {
        num: "iii.",
        title: "Findings",
        body: "Triaged by severity. Each one cites the file, the cause, and the cost of leaving it.",
      },
      {
        num: "iv.",
        title: "Walkthrough",
        body: "Sixty minutes, on Zoom. We go through the findings. You leave with a plan you can hand to anyone.",
      },
    ],
    fit: "You shipped a site with Cursor, Lovable, Replit, Claude, or another platform. It works in the demo. You're now afraid of three things at once and would like to know which fear to honor.",
  },
  {
    id: "security-audit",
    num: "02",
    title: "Security audit",
    short: "Audit",
    eyebrow: "— 02 ⁄ Audit",
    lede: "A quiet sweep for what AI assistants forget — keys, headers, payloads, the back door behind the polite front door.",
    spec: {
      duration: "5–7 days",
      format: "Findings + remediation plan",
      deliverable: "PDF report + fix order",
      scope: "1 site, 1 backend, 1 vendor surface",
      from: "By project",
    },
    checksTitle: "What gets tested.",
    checks: [
      {
        k: "Secrets surface",
        v: "Env vars, hard-coded keys, leaked tokens in client bundles.",
      },
      {
        k: "Auth flow",
        v: "Session, CSRF, brute-force resilience, logout integrity.",
      },
      {
        k: "Headers & transport",
        v: "HSTS, CSP, referrer, frame ancestors, MIME sniffing.",
      },
      {
        k: "Inputs",
        v: "XSS, SQLi/NoSQLi, file upload, server-side validation.",
      },
      {
        k: "Dependencies",
        v: "Known CVEs, abandoned packages, lockfile drift.",
      },
      {
        k: "Vendor blast radius",
        v: "What happens if Stripe, Supabase, or your CMS is breached.",
      },
    ],
    protocol: [
      {
        num: "i.",
        title: "Authorization",
        body: "Written scope of testing. NDA. We agree on what I'm allowed to touch and when.",
      },
      {
        num: "ii.",
        title: "Reconnaissance",
        body: "Surface mapping. Public exposure. Bundles, sourcemaps, the things you forgot were public.",
      },
      {
        num: "iii.",
        title: "Probing",
        body: "Manual + automated. Each finding gets a CVSS, a proof, and a fix.",
      },
      {
        num: "iv.",
        title: "Report",
        body: "A PDF you can hand to a partner, an auditor, or a board. Plus a quiet plan to fix it.",
      },
    ],
    fit: "You're about to take payments, take data, or take fundraising — and you don't know what's leaking from the side of the building you can't see.",
    alt: true,
  },
  {
    id: "rebuild",
    num: "03",
    title: "Rebuild",
    short: "Rebuild",
    eyebrow: "— 03 ⁄ Rebuild",
    lede: "Same intent, real foundation. The right parts of your AI draft stay; the rest gets replaced with code that's documented, tested, and built to last.",
    spec: {
      duration: "2–4 weeks",
      format: "Scoped delivery, deployed + documented",
      deliverable: "Production site, repo, runbook",
      scope: "Up to 12 page templates",
      from: "By project",
    },
    checksTitle: "What gets replaced.",
    checks: [
      { k: "Foundation", v: "Right-sized framework, typed, structured, owned." },
      {
        k: "Component library",
        v: "One small, owned set. No framework salad.",
      },
      {
        k: "Forms & integrations",
        v: "Real validation, real error states, real receipts.",
      },
      {
        k: "Content model",
        v: "Editable by you, no developer required.",
      },
      {
        k: "Deploy pipeline",
        v: "Preview branches, atomic deploys, rollbacks.",
      },
      { k: "Documentation", v: "One README. Boring on purpose." },
    ],
    protocol: [
      {
        num: "i.",
        title: "Scope",
        body: "We agree on a fixed scope. I write the proposal. You sign before I open an editor.",
      },
      {
        num: "ii.",
        title: "Foundation week",
        body: "Repo, design tokens, two reference templates. You see the spine in five days.",
      },
      {
        num: "iii.",
        title: "Build",
        body: "Templates, content, integrations. Daily written notes. Weekly preview links.",
      },
      {
        num: "iv.",
        title: "Handoff",
        body: "Deploy, walkthrough session, 30-day warranty on anything I built. Clean handoff.",
      },
    ],
    fit: "You're spending more time fighting the AI prompt than running your business. Or someone respectable is about to look at your repo and you'd like that to be uneventful.",
  },
  {
    id: "scaling",
    num: "04",
    title: "Scaling",
    short: "Scaling",
    eyebrow: "— 04 ⁄ Scaling",
    lede: "When traffic, load, or surface area outgrows what got it shipped. Real architecture, before the next inflection point — not after the page is on fire.",
    spec: {
      duration: "By project",
      format: "Assessment + implementation sprints",
      deliverable: "Architecture brief + scoped buildout",
      scope: "1 application surface",
      from: "By project",
    },
    checksTitle: "What gets re-architected.",
    checks: [
      {
        k: "Bottlenecks",
        v: "Where the system pinches under real load — DB, queues, cold paths.",
      },
      {
        k: "State",
        v: "Caching, sessions, idempotency. The data you're quietly stale on.",
      },
      {
        k: "Boundaries",
        v: "Service seams, queue topology, what can be made async without regret.",
      },
      {
        k: "Observability",
        v: "Logs, traces, alerts that fire before the customer sends the email.",
      },
      {
        k: "Capacity",
        v: "Headroom, autoscaling, cost ceilings, the next 10×.",
      },
      {
        k: "Failure modes",
        v: "What breaks under partial outage — and how it recovers.",
      },
    ],
    protocol: [
      {
        num: "i.",
        title: "Assessment",
        body: "Reading the system under real conditions — load profiles, traces, the parts you've been afraid to touch.",
      },
      {
        num: "ii.",
        title: "Brief",
        body: "A written architecture document. Where to invest, what to leave alone, in what order.",
      },
      {
        num: "iii.",
        title: "Sprints",
        body: "Implementation in scoped two-week blocks. Each one ships and gets reviewed before the next is signed.",
      },
      {
        num: "iv.",
        title: "Handoff",
        body: "Runbooks, dashboards, and one engineer on your side who knows where the seams are.",
      },
    ],
    fit: "You're past the demo. Real users, real volume, and the parts that worked at 100 are starting to fray at 10,000. You'd like the next inflection to be quiet.",
  },
  {
    id: "coaching",
    num: "05",
    title: "Coaching",
    short: "Coaching",
    eyebrow: "— 05 ⁄ Coaching",
    lede: "Working sessions for founders learning to ship the next version themselves — shoulder to shoulder, in your codebase. Not a course. Your code, your decisions, my eyes on it with you.",
    spec: {
      duration: "By engagement",
      format: "Live working sessions",
      deliverable: "Session recordings + written notes",
      scope: "1 founder, 1 codebase",
      from: "By bundle",
    },
    checksTitle: "What we work on.",
    checks: [
      {
        k: "Reading code",
        v: "How to know what the AI gave you actually does.",
      },
      {
        k: "Decisions",
        v: "When to refactor, when to leave it, when to throw it out.",
      },
      {
        k: "Debugging",
        v: "Following the thread without panicking or rewriting.",
      },
      {
        k: "Shipping",
        v: "Cutting scope, choosing the smaller win, getting it out.",
      },
      {
        k: "Tooling",
        v: "The five things that make the difference. The fifty that don't.",
      },
      {
        k: "Habits",
        v: "Reading before writing. Writing before generating.",
      },
    ],
    protocol: [
      {
        num: "i.",
        title: "Intake",
        body: "Thirty minutes on what you're trying to ship and what's been getting in the way.",
      },
      {
        num: "ii.",
        title: "Sessions",
        body: "Ninety minutes, weekly or bi-weekly. We open your code and work the real problem.",
      },
      {
        num: "iii.",
        title: "Async",
        body: "I read what you wrote between sessions. Notes back, questions answered.",
      },
      {
        num: "iv.",
        title: "Wrap",
        body: "When you no longer need me. The point is not the relationship — it's you not needing it.",
      },
    ],
    fit: "You shipped one version and you're trying to ship the next one without a team. You don't want a tutorial. You want someone in the seat next to you while you make the calls.",
    alt: true,
  },
  {
    id: "retainer",
    num: "06",
    title: "Retainer",
    short: "Retainer",
    eyebrow: "— 06 ⁄ Retainer",
    lede: "Ongoing counsel and capacity, by the month. Senior expertise always within reach for what you're shipping next.",
    spec: {
      duration: "Monthly",
      format: "Async review + quick calls + code check-ins",
      deliverable: "Reviews, decisions, drop-in fixes",
      scope: "1 company, 1 codebase",
      from: "By need",
    },
    checksTitle: "What's included.",
    checks: [
      {
        k: "Reviews",
        v: "Pull-request reads on anything that warrants a second pair of eyes.",
      },
      {
        k: "Calls",
        v: "Two thirty-minute calls a month. More if it's the kind of week that needs them.",
      },
      {
        k: "Decisions",
        v: "When you're stuck on a fork in the road, you have someone to ask.",
      },
      {
        k: "Small fixes",
        v: "Drop-in capacity for things that should take a senior an afternoon.",
      },
      {
        k: "Architecture",
        v: "Light touch, ongoing. The thing you wish you'd talked to a CTO about.",
      },
      {
        k: "Continuity",
        v: "Same person every month. No re-onboarding.",
      },
    ],
    protocol: [
      {
        num: "i.",
        title: "Onboarding",
        body: "One week. I read your repo, your roadmap, and meet whoever else is in the building.",
      },
      {
        num: "ii.",
        title: "Cadence",
        body: "Shared channel, two calls a month, async reviews on what you push.",
      },
      {
        num: "iii.",
        title: "Capacity",
        body: "Up to one engineering day a week of hands-on work. The rest is read, advise, decide.",
      },
      {
        num: "iv.",
        title: "Off-ramp",
        body: "Thirty days notice either way. No claws, no clauses.",
      },
    ],
    fit: "You don't need a CTO yet — but you need a senior in the room when the question comes up. You'd like a quiet, predictable line to one.",
  },
];
---

<Layout
  title="Services"
  description="Code review, security audits, rebuilds, scaling, retainers, coaching — direct work for founders and creators who want what they're building made permanent."
>
  <main class="vr-services">
    <!-- ============ Page header ============ -->
    <section class="vr-services__head vr-shell" data-reveal>
      <span class="vr-eyebrow">— Services ⁄ §00</span>
      <h1 class="vr-h2 vr-services__title">
        From first review<br />
        to ongoing <em>retainer.</em>
      </h1>
      <p class="vr-body vr-services__lede">
        Engagements run the arc — from a single close read of what you've built
        to ongoing counsel that grows with what you're shipping. Scope is set
        in writing before any work begins.
      </p>
    </section>

    <!-- ============ Sticky tabs ============ -->
    <nav class="vr-tabs" aria-label="Services">
      <div class="vr-tabs__inner vr-shell">
        {
          services.map((s) => (
            <a class="vr-tab" href={`#${s.id}`} data-tab={s.id}>
              <span class="vr-tab__num">{s.num}</span>
              <span class="vr-tab__name">{s.title}</span>
            </a>
          ))
        }
      </div>
    </nav>

    <!-- ============ Service articles ============ -->
    {
      services.map((s) => (
        <article
          class:list={["vr-service", { "vr-service--alt": s.alt }]}
          id={s.id}
        >
          <div class="vr-service__inner vr-shell">
            <header class="vr-service__head" data-reveal>
              <span class="vr-eyebrow">{s.eyebrow}</span>
              <h2 class="vr-h2 vr-service__title">{s.title}.</h2>
              <p class="vr-body vr-service__lede">{s.lede}</p>
            </header>

            <div class="vr-service__grid">
              <aside
                class="vr-spec"
                data-reveal
                style="--reveal-delay: 120ms"
              >
                <div class="vr-spec__head">Specification</div>
                <dl class="vr-spec__list">
                  <div>
                    <dt>Duration</dt>
                    <dd>{s.spec.duration}</dd>
                  </div>
                  <div>
                    <dt>Format</dt>
                    <dd>{s.spec.format}</dd>
                  </div>
                  <div>
                    <dt>Deliverable</dt>
                    <dd>{s.spec.deliverable}</dd>
                  </div>
                  <div>
                    <dt>Scope</dt>
                    <dd>{s.spec.scope}</dd>
                  </div>
                  <div>
                    <dt>From</dt>
                    <dd>
                      <strong>{s.spec.from}</strong>
                    </dd>
                  </div>
                </dl>
                <a class="vr-cta vr-spec__cta" href="/book">
                  <span>Book a Call</span>
                  <span class="vr-cta__arrow">→</span>
                </a>
              </aside>

              <div
                class="vr-service__body"
                data-reveal
                style="--reveal-delay: 200ms"
              >
                <h3 class="vr-h3 vr-service__h3">{s.checksTitle}</h3>
                <ul class="vr-checklist">
                  {s.checks.map((c) => (
                    <li>
                      <span>{c.k}</span>
                      <em>{c.v}</em>
                    </li>
                  ))}
                </ul>

                <h3 class="vr-h3 vr-service__h3">How it goes.</h3>
                <ol class="vr-protocol">
                  {s.protocol.map((p) => (
                    <li>
                      <span class="vr-protocol__step">{p.num}</span>
                      <div>
                        <h4>{p.title}</h4>
                        <p>{p.body}</p>
                      </div>
                    </li>
                  ))}
                </ol>

                <h3 class="vr-h3 vr-service__h3">Right for you if…</h3>
                <p class="vr-body">{s.fit}</p>
              </div>
            </div>
          </div>
        </article>
      ))
    }

    <FinalCta section="§07" />
  </main>
</Layout>

<style>
  /* ===== Page header ===== */
  .vr-services__head {
    padding-block: clamp(2rem, 5vw, 3rem) clamp(2.5rem, 6vw, 4rem);
    display: grid;
    gap: 1.5rem;
    border-bottom: 1px solid var(--vr-rule);
  }
  .vr-services__title { max-width: 22ch; }
  .vr-services__title em { color: var(--vr-gold); font-style: italic; }
  .vr-services__lede {
    color: var(--vr-bone-dim);
    max-width: 50ch;
    font-size: var(--vr-step-1);
  }

  /* ===== Sticky tabs ===== */
  .vr-tabs {
    position: sticky;
    top: 0;
    z-index: 10;
    background: oklch(0.06 0 0 / 0.85);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--vr-rule);
  }
  .vr-tabs__inner {
    display: flex;
    overflow-x: auto;
    scrollbar-width: none;
    gap: 0;
  }
  .vr-tabs__inner::-webkit-scrollbar { display: none; }
  .vr-tab {
    flex: 1 1 0;
    min-width: 0;
    padding: 1.1rem clamp(0.75rem, 1.5vw, 1.25rem);
    display: grid;
    grid-template-columns: auto 1fr;
    align-items: baseline;
    gap: 0.6rem;
    border-right: 1px solid var(--vr-rule);
    transition:
      background 240ms var(--vr-ease),
      color 240ms var(--vr-ease);
    position: relative;
    color: var(--vr-bone-dim);
  }
  .vr-tab:last-child { border-right: 0; }
  @media (max-width: 720px) {
    .vr-tab {
      flex: 0 0 auto;
      min-width: max-content;
    }
  }
  .vr-tab::after {
    content: "";
    position: absolute;
    left: 0;
    right: 100%;
    bottom: -1px;
    height: 1px;
    background: var(--vr-gold);
    transition: right 320ms var(--vr-ease);
  }
  .vr-tab:hover {
    color: var(--vr-bone);
    background: oklch(0.10 0.005 80 / 0.7);
  }
  .vr-tab.is-active { color: var(--vr-bone); }
  .vr-tab.is-active::after { right: 0; }
  .vr-tab__num {
    font-family: var(--vr-mono);
    color: var(--vr-gold);
    font-size: 0.78rem;
    letter-spacing: 0.18em;
  }
  .vr-tab__name {
    font-family: var(--vr-serif);
    font-style: italic;
    font-weight: 500;
    font-size: var(--vr-step-1);
    letter-spacing: -0.005em;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* ===== Service article ===== */
  .vr-service {
    padding: clamp(2.5rem, 6vw, 5rem) 0;
    border-bottom: 1px solid var(--vr-rule);
    scroll-margin-top: 90px;
  }
  .vr-service--alt {
    background: linear-gradient(
      180deg,
      transparent 0%,
      oklch(0.085 0.005 80) 30%,
      oklch(0.085 0.005 80) 70%,
      transparent 100%
    );
  }
  .vr-service__head {
    display: grid;
    gap: 1.25rem;
    max-width: 60ch;
    margin-bottom: clamp(2rem, 5vw, 4rem);
  }
  .vr-service__title em { color: var(--vr-gold); font-style: italic; }
  .vr-service__lede { color: var(--vr-bone); }

  .vr-service__grid {
    display: grid;
    grid-template-columns: minmax(260px, 320px) minmax(0, 1fr);
    gap: clamp(2rem, 5vw, 5rem);
    align-items: start;
  }
  @media (max-width: 900px) {
    .vr-service__grid { grid-template-columns: 1fr; }
  }

  /* ===== Spec card ===== */
  .vr-spec {
    border: 1px solid var(--vr-rule);
    background: var(--vr-ink-2);
    position: sticky;
    top: 110px;
  }
  @media (max-width: 900px) {
    .vr-spec { position: static; }
  }
  .vr-spec__head {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--vr-rule);
    font-family: var(--vr-mono);
    font-size: 0.72rem;
    color: var(--vr-gold);
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }
  .vr-spec__list {
    margin: 0;
    padding: 1rem;
    display: grid;
    gap: 0.85rem;
  }
  .vr-spec__list > div {
    display: grid;
    grid-template-columns: 12ch 1fr;
    gap: 1rem;
    padding-bottom: 0.85rem;
    border-bottom: 1px dashed var(--vr-rule);
    align-items: baseline;
  }
  .vr-spec__list > div:last-child {
    border-bottom: 0;
    padding-bottom: 0;
  }
  .vr-spec__list dt {
    font-family: var(--vr-mono);
    font-size: 0.7rem;
    color: var(--vr-bone-faint);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin: 0;
  }
  .vr-spec__list dd {
    margin: 0;
    color: var(--vr-bone);
    font-size: var(--vr-step-0);
  }
  .vr-spec__list dd strong {
    color: var(--vr-gold);
    font-weight: 500;
    font-family: var(--vr-mono);
    letter-spacing: 0.04em;
  }
  .vr-spec__cta {
    margin: 0 1rem 1rem;
    width: calc(100% - 2rem);
    justify-content: center;
  }

  /* ===== Service body ===== */
  .vr-service__body {
    display: grid;
    gap: 2rem;
  }
  .vr-service__h3 {
    font-family: var(--vr-serif);
    font-style: italic;
    font-weight: 500;
    font-size: var(--vr-step-2);
    color: var(--vr-bone);
    padding-top: 1.5rem;
    border-top: 1px solid var(--vr-rule);
    margin: 0;
  }
  .vr-service__body > .vr-service__h3:first-child {
    border-top: 0;
    padding-top: 0;
  }

  .vr-checklist {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0;
  }
  @media (max-width: 700px) {
    .vr-checklist { grid-template-columns: 1fr; }
  }
  .vr-checklist li {
    padding: 1rem 1rem 1rem 1rem;
    border-bottom: 1px solid var(--vr-rule);
    display: grid;
    grid-template-columns: minmax(120px, 160px) 1fr;
    gap: .25rem;
    align-items: baseline;
  }
  @media (max-width: 700px) {
    .vr-checklist li {
      grid-template-columns: 1fr;
      gap: 0.4rem;
      padding: 1rem 0 1rem 1.25rem;
    }
  }
  .vr-checklist li:nth-child(odd) {
    border-right: 1px solid var(--vr-rule);
    padding-right: 1.5rem;
  }
  @media (max-width: 700px) {
    .vr-checklist li:nth-child(odd) {
      border-right: 0;
      padding-right: 1rem;
    }
  }
  .vr-checklist span {
    font-family: var(--vr-mono);
    font-size: 0.74rem;
    color: var(--vr-gold);
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  .vr-checklist em {
    font-family: var(--vr-serif);
    font-style: normal;
    font-size: var(--vr-step-0);
    color: var(--vr-bone-dim);
    line-height: 1.45;
  }

  .vr-protocol {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1.5rem;
  }
  .vr-protocol li {
    display: grid;
    grid-template-columns: 48px 1fr;
    gap: clamp(0.75rem, 2.5vw, 1.25rem);
    padding: 1.2rem 0;
    border-bottom: 1px dashed var(--vr-rule);
  }
  .vr-protocol li:last-child { border-bottom: 0; }
  .vr-protocol__step {
    font-family: var(--vr-serif);
    font-style: italic;
    font-weight: 500;
    font-size: var(--vr-step-2);
    color: var(--vr-gold);
    line-height: 1;
  }
  .vr-protocol h4 {
    margin: 0 0 0.4rem;
    font-family: var(--vr-serif);
    font-weight: 500;
    font-size: var(--vr-step-1);
    letter-spacing: -0.005em;
  }
  .vr-protocol p {
    margin: 0;
    color: var(--vr-bone-dim);
    font-size: var(--vr-step-0);
    max-width: 56ch;
  }

</style>

<script>
  // Sticky-tab active state, driven by which section is in view
  const ids = [
    "code-review",
    "security-audit",
    "rebuild",
    "scaling",
    "coaching",
    "retainer",
  ];
  const sections = ids
    .map((id) => document.getElementById(id))
    .filter((el): el is HTMLElement => el !== null);
  const tabs = Array.from(document.querySelectorAll<HTMLElement>(".vr-tab"));

  const setActive = (id: string) => {
    tabs.forEach((t) => t.classList.toggle("is-active", t.dataset.tab === id));
  };

  if ("IntersectionObserver" in window && sections.length) {
    const io = new IntersectionObserver(
      (entries) => {
        const visible = entries
          .filter((e) => e.isIntersecting)
          .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];
        if (visible) setActive(visible.target.id);
      },
      { threshold: [0.15, 0.4], rootMargin: "-100px 0px -50% 0px" }
    );
    sections.forEach((s) => io.observe(s));
  }

  if (location.hash) setActive(location.hash.slice(1));
  else setActive("code-review");
</script>
