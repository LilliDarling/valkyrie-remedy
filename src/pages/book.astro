---
import Layout from "../layouts/Layout.astro";

const CAL_LINK = "valkyrie-remedy/intro";
const CAL_URL = `https://cal.com/${CAL_LINK}`;
---

<Layout title="Book a Call" bodyClass="vr-page-book">
  <main class="vr-shell vr-stub">
    <div class="vr-stub__row" data-reveal>
      <span class="vr-eyebrow">— Book ⁄ §00</span>
      <div class="vr-stack-3">
        <h1 class="vr-h2">
          Thirty minutes.<br />
          <em>Decide from there.</em>
        </h1>
        <p class="vr-body">
          Walk me through what you've built. Thirty minutes is enough to tell
          whether I'm the right person — and to leave you with a real answer
          either way. The deposit is credited in full toward any engagement
          we agree to.
        </p>
      </div>
    </div>

    <div class="vr-stub__row" data-reveal style="--reveal-delay: 160ms">
      <span class="vr-eyebrow vr-eyebrow--dim">— Logistics</span>
      <dl class="vr-book-spec">
        <div>
          <dt>Length</dt>
          <dd>30 minutes · Google Meet</dd>
        </div>
        <div>
          <dt>Deposit</dt>
          <dd>$50 · Credited toward any engagement</dd>
        </div>
        <div>
          <dt>You bring</dt>
          <dd>Your project & the questions you want answered</dd>
        </div>
        <div>
          <dt>I bring</dt>
          <dd>A second pair of eyes, and an honest answer</dd>
        </div>
      </dl>
    </div>

    <div class="vr-stub__row vr-stub__row--stacked" data-reveal style="--reveal-delay: 280ms">
      <span class="vr-eyebrow vr-eyebrow--dim">— Schedule</span>
      <div class="vr-cal">
        <div id="cal-embed" class="vr-cal__embed" aria-label="Cal.com booking"></div>
        <noscript>
          <p class="vr-meta vr-cal__fallback-meta">
            JavaScript is required to load the scheduler.
          </p>
          <a
            class="vr-cta"
            href={CAL_URL}
            target="_blank"
            rel="noopener noreferrer"
          >
            <span>Open scheduler</span>
            <span class="vr-cta__arrow">↗</span>
          </a>
        </noscript>
      </div>
    </div>
  </main>

  <script is:inline define:vars={{ CAL_LINK }}>
    (function (C, A, L) {
      let p = function (a, ar) { a.q.push(ar); };
      let d = C.document;
      C.Cal = C.Cal || function () {
        let cal = C.Cal;
        let ar = arguments;
        if (!cal.loaded) {
          cal.ns = {};
          cal.q = cal.q || [];
          d.head.appendChild(d.createElement("script")).src = A;
          cal.loaded = true;
        }
        if (ar[0] === L) {
          const api = function () { p(api, arguments); };
          const namespace = ar[1];
          api.q = api.q || [];
          if (typeof namespace === "string") {
            cal.ns[namespace] = cal.ns[namespace] || api;
            p(cal.ns[namespace], ar);
            p(cal, ["initNamespace", namespace]);
          } else p(cal, ar);
          return;
        }
        p(cal, ar);
      };
    })(window, "https://app.cal.com/embed/embed.js", "init");

    Cal("init", "intro", { origin: "https://cal.com" });

    Cal.ns.intro("inline", {
      elementOrSelector: "#cal-embed",
      calLink: CAL_LINK,
      config: { layout: "month_view", theme: "dark" },
    });

    Cal.ns.intro("ui", {
      theme: "dark",
      hideEventTypeDetails: false,
      layout: "month_view",
      cssVarsPerTheme: {
        dark: {
          "cal-brand": "#a44434",
          "cal-bg": "#060606",
          "cal-bg-emphasis": "#0c0c0c",
          "cal-bg-muted": "#14130f",
          "cal-border": "rgba(255,255,255,0.10)",
          "cal-border-subtle": "rgba(255,255,255,0.06)",
          "cal-text": "#e9e3d5",
          "cal-text-emphasis": "#e9e3d5",
          "cal-text-muted": "rgba(233,227,213,0.55)",
        },
      },
    });
  </script>
</Layout>

<style>
  .vr-stub {
    min-height: 70vh;
    display: grid;
    align-content: start;
    gap: 1.5rem;
    padding-block: 4rem 6rem;
  }
  .vr-stub__row {
    display: grid;
    grid-template-columns: minmax(120px, 200px) 1fr;
    gap: clamp(1rem, 4vw, 4rem);
    align-items: start;
    padding-block: 2rem;
  }
  @media (max-width: 720px) {
    .vr-stub__row { grid-template-columns: 1fr; gap: 1rem; }
  }

  .vr-stub__row--stacked {
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  .vr-stack-3 > * + * { margin-top: 2rem; }

  .vr-stub__row .vr-h2 em {
    color: var(--vr-gold);
    font-style: italic;
  }

  .vr-book-spec {
    margin: 0;
    display: grid;
    gap: 1rem;
    max-width: 60ch;
  }
  .vr-book-spec > div {
    display: grid;
    grid-template-columns: 11ch 1fr;
    gap: 1rem;
    padding-bottom: 1rem;
    border-bottom: 1px dashed var(--vr-rule);
    align-items: baseline;
  }
  @media (max-width: 480px) {
    .vr-book-spec > div {
      grid-template-columns: 1fr;
      gap: 0.35rem;
    }
  }
  .vr-book-spec > div:last-child { border-bottom: 0; }
  .vr-book-spec dt {
    font-family: var(--vr-mono);
    font-size: 0.74rem;
    color: var(--vr-bone-faint);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    margin: 0;
  }
  .vr-book-spec dd {
    margin: 0;
    color: var(--vr-bone);
    font-size: var(--vr-step-1);
  }

  .vr-cal {
    display: grid;
    gap: 1.25rem;
    width: 100%;
  }
  .vr-cal__embed {
    width: 100%;
    min-height: 680px;
    overflow: hidden;
  }
  .vr-cal__fallback-meta { margin: 0; }
</style>
