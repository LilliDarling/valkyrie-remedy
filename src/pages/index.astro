---
import Layout from "../layouts/Layout.astro";
import FinalCta from "../components/FinalCta.astro";

const capabilities: {
  num: string;
  name: string;
  desc: string;
  duration: string;
  format: string;
  kind: string;
  href: string;
}[] = [
  {
    num: "01",
    name: "Code review",
    desc: "A close read of what you've built — what holds, what strains, what won't survive a real user.",
    duration: "3–5 days",
    format: "Written report + walkthrough",
    kind: "Code audit",
    href: "/services#code-review",
  },
  {
    num: "02",
    name: "Security audit",
    desc: "A quiet sweep for what AI assistants forget — keys, headers, payloads, the back door behind the polite front door.",
    duration: "5–7 days",
    format: "Findings + remediation plan",
    kind: "Security review",
    href: "/services#security-audit",
  },
  {
    num: "03",
    name: "Rebuild",
    desc: "Same intent, real foundation. The right parts stay; the rest gets replaced with code that's documented, tested, and built to last.",
    duration: "2–4 weeks",
    format: "Scoped delivery, deployed + documented",
    kind: "Replatform",
    href: "/services#rebuild",
  },
  {
    num: "04",
    name: "Scaling",
    desc: "When traffic, load, or surface area outgrows what got it shipped. Real architecture, before the next inflection point.",
    duration: "TBD",
    format: "Assessment report + implementation sprints",
    kind: "Infrastructure",
    href: "/services#scaling",
  },
  {
    num: "05",
    name: "Coaching",
    desc: "Working sessions for founders learning to ship the next version themselves — shoulder to shoulder, in your codebase.",
    duration: "TBD",
    format: "Live working sessions",
    kind: "Advisory",
    href: "/services#coaching",
  },
  {
    num: "06",
    name: "Retainer",
    desc: "Ongoing counsel and capacity, by the month. Senior expertise always within reach for what you're shipping next.",
    duration: "Monthly",
    format: "Async review + quick calls + code check-ins",
    kind: "Fractional CTO",
    href: "/services#retainer",
  },
];

const steps: { num: string; title: string; body: string }[] = [
  {
    num: "·01",
    title: "Intro call",
    body: "Thirty minutes, paid. You tell me what's broken. I tell you if I'm the right person to fix it. If we move forward, the fee rolls into your project.",
  },
  {
    num: "·02",
    title: "Scoped proposal",
    body: "Written scope, fixed price. You know exactly what you're getting before you agree to anything.",
  },
  {
    num: "·03",
    title: "The work",
    body: "I work with daily notes in a shared channel. No black box — you always know where things stand.",
  },
  {
    num: "·04",
    title: "Handoff",
    body: "Documented. Whatever we built, found, or fixed — it's yours, in writing, with enough context that it doesn't die with this engagement.",
  },
];
---

<Layout title="Valkyrie Remedy">
  <!-- ============ HERO ============ -->
  <section class="vr-hero" aria-label="Hero">
    <div class="vr-hero__inner vr-shell">
      <!-- status bar -->
      <div class="vr-hero__status" data-reveal style="--reveal-delay: 0ms">
        <span class="vr-hero__status-cell">
          <span class="vr-tag__dot"></span>
          <span>Now booking · Q2 / Q3 2026</span>
        </span>
        <span class="vr-hero__status-cell vr-hero__status-cell--right">
          <span class="vr-meta">By application · Private Practice</span>
        </span>
      </div>

      <div class="vr-forge">
        <div class="vr-forge__type">
          <p class="vr-eyebrow" data-reveal style="--reveal-delay: 220ms">
            — A practice for founders & creators
          </p>

          <h1 class="vr-h1 vr-forge__h1" data-reveal style="--reveal-delay: 320ms">
            From vision<br />
            to <em>foundation.</em>
          </h1>

          <p class="vr-body" data-reveal style="--reveal-delay: 480ms">
            Code review, security audits, rebuilds, scaling, retainers,
            coaching — direct work for founders and creators who want what
            they're building made permanent. No handoffs, no agency middle,
            no contractor pipeline.
          </p>

          <div class="vr-row" data-reveal style="--reveal-delay: 600ms">
            <a class="vr-cta" href="/book">
              <span>Book a Call</span>
              <span class="vr-cta__arrow">→</span>
            </a>
            <a class="vr-cta vr-cta--ghost" href="/services">
              <span>See Services</span>
              <span class="vr-cta__arrow">→</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ THE WORK ============ -->
  <section class="vr-work vr-shell" id="work">
    <header class="vr-work__head" data-reveal>
      <span class="vr-eyebrow">— The work ⁄ §02</span>
      <div class="vr-work__intro">
        <h2 class="vr-h2 vr-work__title">
          From first review<br />
          to ongoing <em>retainer.</em>
        </h2>
        <p class="vr-body vr-work__lede">
          Engagements run the arc — from a single close read of what you've
          built to ongoing counsel that grows with what you're shipping.
          Scope is set in writing before any work begins.
        </p>
      </div>
    </header>

    <ul class="vr-capabilities">
      {
        capabilities.map((c, i) => (
          <li
            class="vr-cap"
            data-reveal
            style={`--reveal-delay: ${80 + i * 60}ms`}
          >
            <header class="vr-cap__top">
              <span class="vr-cap__num">{c.num}</span>
              <span class="vr-cap__kind">{c.kind}</span>
            </header>
            <h3 class="vr-cap__name">{c.name}</h3>
            <p class="vr-cap__desc">{c.desc}</p>
            <dl class="vr-cap__meta">
              <div>
                <dt>Duration</dt>
                <dd>{c.duration}</dd>
              </div>
              <div>
                <dt>Format</dt>
                <dd>{c.format}</dd>
              </div>
            </dl>
            <a class="vr-cap__more" href={c.href}>
              Read more <span aria-hidden="true">→</span>
            </a>
          </li>
        ))
      }
    </ul>
  </section>

  <!-- ============ PROCESS ============ -->
  <section class="vr-process vr-shell">
    <div class="vr-process__inner">
      <div class="vr-process__head" data-reveal>
        <span class="vr-eyebrow">— Process ⁄ §03</span>
        <h2 class="vr-h2">
          How the work<br /><em>starts.</em>
        </h2>
      </div>

      <ol class="vr-process__steps">
        {
          steps.map((step, i) => (
            <li data-reveal style={`--reveal-delay: ${120 + i * 120}ms`}>
              <span class="vr-process__num">{step.num}</span>
              <h3>{step.title}</h3>
              <p>{step.body}</p>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <!-- ============ FINAL CTA ============ -->
  <FinalCta section="§04" />
</Layout>

<style>
  /* ===== Hero ===== */
  .vr-hero { padding-block: 1rem clamp(3rem, 8vw, 6rem); }
  .vr-hero__inner { position: relative; }

  .vr-hero__status {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    padding: 0.6rem 0;
    border-top: 1px solid var(--vr-rule);
    border-bottom: 1px solid var(--vr-rule);
    font-family: var(--vr-mono);
    font-size: var(--vr-step--1);
    color: var(--vr-bone-faint);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: clamp(2rem, 6vw, 5rem);
  }
  .vr-hero__status-cell {
    display: inline-flex;
    gap: 0.6rem;
    align-items: center;
  }
  .vr-hero__status-cell--right { justify-content: flex-end; }

  @media (max-width: 600px) {
    .vr-hero__status {
      grid-template-columns: 1fr;
      gap: 0.5rem;
      letter-spacing: 0.08em;
    }
    .vr-hero__status-cell--right { justify-content: flex-start; }
  }

  /* Forge */
  .vr-forge { padding: clamp(1.5rem, 4vw, 2rem) 0 1rem; }
  .vr-forge__type { display: grid; gap: clamp(1rem, 2.5vw, 1.4rem); }
  .vr-forge__h1 em { color: var(--vr-gold); font-style: italic; }

  /* ===== The work ===== */
  .vr-work { padding-block: clamp(5rem, 10vw, 8rem); }

  .vr-work__head {
    display: grid;
    grid-template-columns: minmax(140px, 200px) 1fr;
    gap: clamp(1.5rem, 5vw, 4rem);
    align-items: start;
    padding-bottom: clamp(2.5rem, 5vw, 4rem);
  }
  @media (max-width: 720px) {
    .vr-work__head { grid-template-columns: 1fr; }
  }

  .vr-work__intro {
    display: grid;
    gap: clamp(1.25rem, 2.5vw, 1.75rem);
  }
  .vr-work__title em { color: var(--vr-iron); font-style: italic; }
  .vr-work__lede { margin: 0; max-width: 56ch; }

  .vr-capabilities {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border-top: 1px solid var(--vr-rule);
  }

  .vr-cap {
    padding: clamp(2rem, 3vw, 2.75rem) clamp(1.5rem, 2.5vw, 2.25rem);
    border-right: 1px solid var(--vr-rule);
    border-bottom: 1px solid var(--vr-rule);
    display: grid;
    gap: 1.1rem;
    align-content: start;
    transition: background 280ms var(--vr-ease);
  }
  .vr-cap:hover {
    background: linear-gradient(180deg, oklch(0.10 0.01 30) 0%, transparent 100%);
  }
  .vr-cap:nth-child(3n) { border-right: 0; }
  .vr-cap:nth-last-child(-n+3) { border-bottom: 0; }

  @media (max-width: 900px) {
    .vr-capabilities { grid-template-columns: repeat(2, 1fr); }
    .vr-cap:nth-child(3n) { border-right: 1px solid var(--vr-rule); }
    .vr-cap:nth-child(2n) { border-right: 0; }
    .vr-cap:nth-last-child(-n+3) { border-bottom: 1px solid var(--vr-rule); }
    .vr-cap:nth-last-child(-n+2) { border-bottom: 0; }
  }

  @media (max-width: 600px) {
    .vr-capabilities { grid-template-columns: 1fr; }
    .vr-cap,
    .vr-cap:nth-child(2n),
    .vr-cap:nth-child(3n) {
      padding: 2rem 0;
      border-right: 0;
      border-bottom: 1px solid var(--vr-rule);
    }
    .vr-cap:nth-last-child(-n+3),
    .vr-cap:nth-last-child(-n+2) {
      border-bottom: 1px solid var(--vr-rule);
    }
    .vr-cap:last-child { border-bottom: 0; }
  }

  .vr-cap__top {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    color: var(--vr-bone-faint);
    font-family: var(--vr-mono);
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }
  .vr-cap__num {
    font-family: var(--vr-serif);
    font-style: italic;
    font-weight: 500;
    font-size: 1.1rem;
    color: var(--vr-iron);
    letter-spacing: 0;
  }
  .vr-cap__kind { color: var(--vr-iron); }

  .vr-cap__name {
    font-family: var(--vr-serif);
    font-weight: 500;
    font-style: italic;
    font-size: var(--vr-step-2);
    letter-spacing: -0.01em;
    color: var(--vr-bone);
    margin: 0;
  }

  .vr-cap__desc {
    font-family: var(--vr-serif-body);
    font-size: var(--vr-step-1);
    line-height: 1.5;
    color: var(--vr-bone-dim);
    margin: 0;
  }

  .vr-cap__meta {
    display: grid;
    gap: 0.5rem;
    margin: 0;
    padding: 1rem 0 0;
    border-top: 1px dashed var(--vr-rule);
    font-family: var(--vr-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .vr-cap__meta > div {
    display: grid;
    grid-template-columns: 8ch 1fr;
    gap: 0.9rem;
  }
  .vr-cap__meta dt { color: var(--vr-bone-faint); margin: 0; }
  .vr-cap__meta dd { color: var(--vr-bone); margin: 0; }

  .vr-cap__more {
    color: var(--vr-iron);
    font-family: var(--vr-mono);
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    border-bottom: 1px solid transparent;
    padding-bottom: 2px;
    align-self: start;
    transition:
      border-color 240ms var(--vr-ease),
      color 240ms var(--vr-ease);
  }
  .vr-cap__more:hover {
    color: var(--vr-iron-warm);
    border-color: var(--vr-iron);
  }

  /* ===== Process ===== */
  .vr-process { padding-block: clamp(4rem, 8vw, 6rem); }
  .vr-process__inner {
    display: grid;
    grid-template-columns: minmax(220px, 1fr) minmax(0, 2fr);
    gap: clamp(2rem, 5vw, 5rem);
  }
  @media (max-width: 900px) {
    .vr-process__inner { grid-template-columns: 1fr; }
  }
  .vr-process__head {
    display: grid;
    gap: 1.2rem;
    align-content: start;
    position: sticky;
    top: 2rem;
  }
  @media (max-width: 900px) {
    .vr-process__head { position: static; }
  }
  .vr-process__head em { color: var(--vr-gold); font-style: italic; }

  .vr-process__steps {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0;
  }
  .vr-process__steps li {
    position: relative;
    background: var(--vr-ink);
    padding: clamp(1.1rem, 2vw, 1.6rem) clamp(1rem, 2vw, 1.5rem)
             clamp(1.1rem, 2vw, 1.6rem) 0;
    display: grid;
    grid-template-columns: clamp(80px, 14vw, 140px) 1fr;
    grid-template-areas:
      "num title"
      "num body";
    column-gap: clamp(1rem, 3vw, 2.5rem);
    row-gap: 0.55rem;
    align-items: start;
    border-top: 1px solid var(--vr-rule);
    transition:
      background 360ms var(--vr-ease),
      padding-left 360ms var(--vr-ease);
  }
  .vr-process__num { grid-area: num; }
  .vr-process__steps h3 { grid-area: title; }
  .vr-process__steps p { grid-area: body; }
  .vr-process__steps li:last-child { border-bottom: 1px solid var(--vr-rule); }

  .vr-process__steps li::before {
    content: "";
    position: absolute;
    left: 0;
    top: -1px;
    bottom: -1px;
    width: 2px;
    background: var(--vr-gold);
    transform: scaleY(0);
    transform-origin: top;
    transition: transform 420ms var(--vr-ease);
  }
  .vr-process__steps li:hover {
    background: linear-gradient(180deg, oklch(0.10 0.01 30) 0%, transparent 100%);
    padding-left: clamp(1rem, 2vw, 1.5rem);
  }
  .vr-process__steps li:hover::before { transform: scaleY(1); }

  @media (max-width: 720px) {
    .vr-process__steps li {
      grid-template-columns: 1fr;
      grid-template-areas:
        "num"
        "title"
        "body";
      row-gap: 0.5rem;
      padding: 1.25rem 0;
    }
    .vr-process__steps li:hover { padding-left: 0; }
  }

  .vr-process__steps h3 {
    margin: 0 0 0.4rem;
    font-family: var(--vr-serif);
    font-weight: 500;
    font-style: italic;
    font-size: var(--vr-step-2);
    letter-spacing: -0.01em;
    color: var(--vr-bone);
    line-height: 1.1;
  }
  .vr-process__steps p {
    margin: 0;
    color: var(--vr-bone-dim);
    font-family: var(--vr-serif-body);
    font-size: var(--vr-step-1);
    line-height: 1.55;
    max-width: 54ch;
  }
  .vr-process__num {
    display: block;
    font-family: var(--vr-serif);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(2.75rem, 6vw, 4.25rem);
    color: var(--vr-gold);
    letter-spacing: -0.02em;
    line-height: 0.95;
    align-self: start;
    transition: color 360ms var(--vr-ease), transform 360ms var(--vr-ease);
  }
  .vr-process__steps li:hover .vr-process__num {
    color: var(--vr-iron-warm, var(--vr-gold));
    transform: translateX(-2px);
  }

  .vr-row {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }
</style>
